# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Serverless API routes (/api/admin/*)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

VITE_DEBUG_SUPABASE=

# Supabase auth: keep users signed in across refresh/browser restart.
VITE_SUPABASE_PERSIST_SESSION=
VITE_SUPABASE_AUTO_REFRESH_TOKEN=
VITE_SUPABASE_DETECT_SESSION_IN_URL=

# Dev only: disable React Fast Refresh (no auto UI refresh on save).
VITE_DISABLE_FAST_REFRESH=
