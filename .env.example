# Frontend (Vite)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Optional: set to "false" to disable React StrictMode locally (reduces Supabase auth lock warnings in dev).
VITE_STRICT_MODE="true"

# Serverless API routes (/api/admin/*)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional: rate limit serverless admin endpoints (best-effort; per-instance)
RATE_LIMIT_ENABLED="true"

# Optional (only for /api/admin/bootstrap)
BOOTSTRAP_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
